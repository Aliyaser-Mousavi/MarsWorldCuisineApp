{
  "expo": {
    "name": "marsWorldCuisine",
    "slug": "marsWorldCuisine",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#351401",
      "media": {
        "android": "./assets/splash.png",
        "ios": "./assets/splash.png"
      }
    },
    "android": {
      "package": "com.yourcompany.marsworldcuisine",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#351401"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.marsworldcuisine"
    },
    "assetBundlePatterns": ["**/*"]
  }
}
